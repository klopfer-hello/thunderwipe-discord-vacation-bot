DISCORD_TOKEN=
DB_PASSWORD=choose_a_strong_password

# Docker Compose sets DATABASE_URL automatically — leave blank here for local dev (SQLite)
DATABASE_URL=

# Comma-separated role names that gate the moderator commands
# (/fehlende, /urlaube_anzeigen, /urlaub_fuer). A member needs at least
# one of the listed roles to use them. Leave EMPTY to make these commands
# available to everyone on the server.
# Examples:
#   MODERATION_ROLES=Officer
#   MODERATION_ROLES=Officer, Admin, GM
MODERATION_ROLES=
HEATMAP_CHANNEL_ID=
VACATION_CHANNEL_ID=

# Optional: Discord server (guild) ID. If set, slash commands are registered
# directly on this guild and appear instantly. If empty, they register globally
# and can take up to an hour to appear. For development, always set this.
GUILD_ID=
